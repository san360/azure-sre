# Contoso Meals - Service Endpoints
# Generated by deploy.sh after deployment.
# Copy to .env and update values, or let deploy.sh generate it automatically.

# Container App endpoints
MENU_API_URL=https://menu-api.<your-env-domain>.swedencentral.azurecontainerapps.io
WEB_UI_URL=https://web-ui.<your-env-domain>.swedencentral.azurecontainerapps.io

# AKS LoadBalancer endpoints (public IPs assigned after kubectl apply)
ORDER_API_URL=http://<order-api-external-ip>
PAYMENT_API_URL=http://<payment-service-external-ip>

# Jira Service Management
JIRA_URL=https://jira-sm.<your-env-domain>.swedencentral.azurecontainerapps.io

# MCP Atlassian Server
MCP_ATLASSIAN_URL=https://mcp-atlassian.<your-env-domain>.swedencentral.azurecontainerapps.io/mcp

# Azure resource identifiers
RESOURCE_GROUP=rg-contoso-meals
AKS_CLUSTER=aks-contoso-meals
LOAD_TEST_RESOURCE=lt-contoso-meals

# PostgreSQL
POSTGRES_FQDN=psql-contoso-meals.postgres.database.azure.com

# SRE Agent
SRE_AGENT_PORTAL_URL=
SRE_AGENT_IDENTITY_CLIENT_ID=
