{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "swedencentral"
    },
    "prefix": {
      "value": "contoso-meals"
    },
    "enableChaos": {
      "value": true
    },
    "enableLoadTesting": {
      "value": true
    },
    "enableJira": {
      "value": true
    },
    "enableSreAgent": {
      "value": true
    },
    "sreAgentAccessLevel": {
      "value": "High"
    },
    "sreAgentMode": {
      "value": "Review"
    },
    "targetResourceGroups": {
      "value": []
    },
    "targetSubscriptions": {
      "value": []
    },
    "postgresLocation": {
      "value": "swedencentral"
    },
    "deployerPrincipalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    }
  }
}
