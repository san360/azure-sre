        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate Random Order Data" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">
import java.util.UUID

def rand = new Random()

// Random customer from seeded data
def customerIds = [
    "00000000-0000-0000-0000-000000000001",
    "00000000-0000-0000-0000-000000000002",
    "00000000-0000-0000-0000-000000000003",
    "00000000-0000-0000-0000-000000000004",
    "00000000-0000-0000-0000-000000000005"
]
vars.put("customerId", customerIds[rand.nextInt(customerIds.size())])

// Random restaurant
vars.put("restaurantId", "restaurant-" + (rand.nextInt(5) + 1))

// Menu items pool
def menuItems = [
    ["name": "Classic Burger", "price": 12.99],
    ["name": "Truffle Fries", "price": 7.99],
    ["name": "Milkshake", "price": 6.99],
    ["name": "Caesar Salad", "price": 10.99],
    ["name": "Margherita Pizza", "price": 14.99],
    ["name": "Grilled Chicken Wrap", "price": 11.49],
    ["name": "Fish and Chips", "price": 13.99],
    ["name": "Veggie Bowl", "price": 9.99]
]

// Pick 1-3 random unique items with random quantities
def numItems = rand.nextInt(3) + 1
def selectedItems = []
def total = 0.0
def shuffled = (0..&lt;menuItems.size()).toList()
Collections.shuffle(shuffled, rand)
for (int i = 0; i &lt; numItems; i++) {
    def item = menuItems[shuffled[i]]
    def qty = rand.nextInt(2) + 1
    selectedItems.add("{\"name\":\"" + item.name + "\",\"price\":" + item.price + ",\"quantity\":" + qty + "}")
    total += item.price * qty
}

vars.put("orderItems", "[" + selectedItems.join(",") + "]")
vars.put("totalAmount", String.format("%.2f", total))

// Random payment method
def paymentMethods = ["credit_card", "debit_card", "apple_pay", "google_pay"]
vars.put("paymentMethod", paymentMethods[rand.nextInt(paymentMethods.size())])
          </stringProp>
        </JSR223PreProcessor>
        <hashTree/>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /orders" enabled="true">
          <stringProp name="HTTPSampler.domain">${ORDER_API_HOST}</stringProp>
