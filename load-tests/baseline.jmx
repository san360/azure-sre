        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate Random Payment Data" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">
import java.util.UUID

def rand = new Random()

// Random order ID (UUID)
vars.put("orderId", UUID.randomUUID().toString())

// Random amount between 5.00 and 59.99
def amount = (rand.nextInt(5500) + 500) / 100.0
vars.put("payAmount", String.format("%.2f", amount))

// Random payment method
def paymentMethods = ["credit_card", "debit_card", "apple_pay", "google_pay"]
vars.put("payMethod", paymentMethods[rand.nextInt(paymentMethods.size())])
          </stringProp>
        </JSR223PreProcessor>
